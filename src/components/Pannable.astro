---
// Pannable.astro
// Wraps any mermaid (or other SVG) content with pan & zoom behaviour.
// The rehypeMermaid plugin renders <pre class="mermaid"> → <svg> at build
// time, so the slot will contain a plain <svg> element by the time the
// browser sees it.
---

<div class="pan-root" data-pannable>
  <!-- diagram lives here -->
  <div class="pan-stage">
    <div class="pan-canvas">
      <slot />
    </div>
  </div>

  <!-- controls -->
  <div class="pan-controls" aria-label="Zoom controls">
    <button class="pan-btn" data-zoom="in"  aria-label="Zoom in">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <circle cx="6.5" cy="6.5" r="5"/>
        <line x1="10.5" y1="10.5" x2="14.5" y2="14.5"/>
        <line x1="6.5" y1="4" x2="6.5" y2="9"/>
        <line x1="4" y1="6.5" x2="9" y2="6.5"/>
      </svg>
    </button>
    <hr class="pan-divider" />
    <button class="pan-btn" data-zoom="reset" aria-label="Reset view">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2 8a6 6 0 1 0 1.5-3.9"/>
        <polyline points="2 3 2 8 7 8"/>
      </svg>
    </button>
    <hr class="pan-divider" />
    <button class="pan-btn" data-zoom="out" aria-label="Zoom out">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <circle cx="6.5" cy="6.5" r="5"/>
        <line x1="10.5" y1="10.5" x2="14.5" y2="14.5"/>
        <line x1="4" y1="6.5" x2="9" y2="6.5"/>
      </svg>
    </button>
  </div>
</div>

<style>
  /* ── root container ─────────────────────────────────────────────── */
  .pan-root {
    position: relative;
    width: 100%;
    /* respect any height set on the element; fall back to a comfortable default */
    height: var(--pannable-height, 420px);
    background: var(--sl-color-bg-sidebar, #f6f6f8);
    border: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    border-radius: 10px;
    overflow: hidden;
    /* subtle inner shadow to reinforce the "viewport" feel */
    box-shadow: inset 0 0 0 1px color-mix(in srgb, currentColor 6%, transparent);
  }

  /* ── scrollable stage (overflow hidden so canvas can float freely) */
  .pan-stage {
    width: 100%;
    height: 100%;
    overflow: hidden;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }

  .pan-stage.is-dragging {
    cursor: grabbing;
  }

  /* ── the element we actually transform ─────────────────────────── */
  .pan-canvas {
    display: inline-flex;       /* shrink-wrap the SVG */
    align-items: flex-start;
    transform-origin: 0 0;
    /* NOTE: no will-change here — it forces a raster compositing layer
       which blurs vector SVG content when zoomed in */
  }

  /* make sure the mermaid SVG itself plays nice */
  .pan-canvas :global(svg) {
    display: block;
    /* Only neutralise restrictive max-width rules from Starlight/Tailwind.
       Do NOT set width/height — SVGs with only a viewBox rely on the
       browser's default intrinsic sizing; overriding to 'auto' collapses them. */
    max-width: none !important;
  }

  /* ── control panel ──────────────────────────────────────────────── */
  .pan-controls {
    position: absolute;
    bottom: 16px;
    right: 16px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 4px;
    background: color-mix(in srgb, var(--sl-color-bg, #fff) 80%, transparent);
    backdrop-filter: blur(10px) saturate(160%);
    -webkit-backdrop-filter: blur(10px) saturate(160%);
    border: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    border-radius: 10px;
    box-shadow:
      0 4px 16px color-mix(in srgb, #000 12%, transparent),
      0 1px 3px  color-mix(in srgb, #000 8%, transparent);
  }

  .pan-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 7px;
    color: color-mix(in srgb, currentColor 70%, transparent);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, transform 0.1s;
  }

  .pan-btn:hover {
    background: color-mix(in srgb, var(--sl-color-accent, #7c3aed) 12%, transparent);
    color: var(--sl-color-accent, #7c3aed);
  }

  .pan-btn:active {
    transform: scale(0.88);
  }

  .pan-btn svg {
    width: 15px;
    height: 15px;
  }

  .pan-divider {
    all: unset;
    display: block;
    height: 1px;
    margin: 2px 4px;
    background: color-mix(in srgb, currentColor 14%, transparent);
  }</style>

<script>
  // Run once per Pannable instance on the page.
  document.querySelectorAll<HTMLElement>("[data-pannable]").forEach((root) => {
    const stage  = root.querySelector<HTMLElement>(".pan-stage")!;
    const canvas = root.querySelector<HTMLElement>(".pan-canvas")!;

    // ── state ────────────────────────────────────────────────────────
    let tx = 0, ty = 0, scale = 1;
    const STEP    = 0.2;
    const MIN     = 0.2;
    const MAX     = 4;

    // ── helpers ──────────────────────────────────────────────────────
    function clampScale(s: number) {
      return Math.min(MAX, Math.max(MIN, s));
    }

    function applyTransform() {
      canvas.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
    }

    function centerContent() {
      // After the first paint we know the SVG size; start it centred.
      const stageW = stage.offsetWidth;
      const stageH = stage.offsetHeight;
      const cW = canvas.scrollWidth;
      const cH = canvas.scrollHeight;
      tx = Math.max(0, (stageW - cW) / 2);
      ty = Math.max(0, (stageH - cH) / 2);
      applyTransform();
    }

    // center on first render (SVG is static so immediate is fine)
    requestAnimationFrame(centerContent);

    // ── pan (pointer drag) ───────────────────────────────────────────
    let dragging = false;
    let ox = 0, oy = 0;

    stage.addEventListener("pointerdown", (e) => {
      // only primary button
      if (e.button !== 0) return;
      dragging = true;
      ox = e.clientX - tx;
      oy = e.clientY - ty;
      stage.setPointerCapture(e.pointerId);
      stage.classList.add("is-dragging");
    });

    stage.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      tx = e.clientX - ox;
      ty = e.clientY - oy;
      applyTransform();
    });

    const stopDrag = () => {
      dragging = false;
      stage.classList.remove("is-dragging");
    };
    stage.addEventListener("pointerup",     stopDrag);
    stage.addEventListener("pointercancel", stopDrag);

    // ── zoom (wheel) ─────────────────────────────────────────────────
    stage.addEventListener("wheel", (e) => {
      e.preventDefault();
      const rect   = stage.getBoundingClientRect();
      const mouseX = e.clientX - rect.left;
      const mouseY = e.clientY - rect.top;

      const delta    = e.deltaY < 0 ? 1 + STEP : 1 - STEP;
      const newScale = clampScale(scale * delta);
      const ratio    = newScale / scale;

      // zoom towards the cursor
      tx = mouseX - ratio * (mouseX - tx);
      ty = mouseY - ratio * (mouseY - ty);
      scale = newScale;
      applyTransform();
    }, { passive: false });

    // ── zoom buttons ─────────────────────────────────────────────────
    root.querySelectorAll<HTMLButtonElement>("[data-zoom]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const action = btn.dataset.zoom;

        if (action === "reset") {
          scale = 1;
          centerContent(); // also resets tx/ty
          return;
        }

        // zoom toward stage centre
        const cx = stage.offsetWidth  / 2;
        const cy = stage.offsetHeight / 2;
        const newScale = clampScale(scale * (action === "in" ? 1 + STEP : 1 - STEP));
        const ratio    = newScale / scale;
        tx = cx - ratio * (cx - tx);
        ty = cy - ratio * (cy - ty);
        scale = newScale;
        applyTransform();
      });
    });
  });
</script>
